 *
 * CREDITS (Optional):
 * Based on "[Original Title]" by [Original Author]
 * [Platform]: [URL]
 *
 * ===================================================================================
 *
 * DESCRIPTION:
 * [2-3 sentences describing the post-processing effect.]
 *
 * FEATURES:
 * - [Feature list]
 *
 * IMPLEMENTATION OVERVIEW:
 * 1. [Steps]
 *
 * ===================================================================================
 */

// ============================================================================
// TECHNIQUE GUARD
// ============================================================================
#ifndef __AS_GFX_[EffectName]_1_fx
#define __AS_GFX_[EffectName]_1_fx

// ============================================================================
// INCLUDES
// ============================================================================
#include "ReShade.fxh"
#include "AS_Utils.1.fxh"

// ============================================================================
// SHADER DESCRIPTOR
// ============================================================================
uniform int as_shader_descriptor <ui_type = "radio"; ui_label = " "; ui_text = "AS StageFX | [Effect Display Name] | [1-2 sentence description of what the effect does visually] | by [Author Name]"; > = 0;

// ============================================================================
// NAMESPACE
// ============================================================================
namespace AS_[EffectName] {

// ============================================================================
// TUNABLE CONSTANTS
// ============================================================================
static const float EFFECT_INTENSITY_MIN = 0.0;
static const float EFFECT_INTENSITY_MAX = 2.0;
static const float EFFECT_INTENSITY_DEFAULT = 1.0;

// Blur radius for multi-pass example
static const float BLUR_RADIUS_MIN = 0.0;
static const float BLUR_RADIUS_MAX = 10.0;
static const float BLUR_RADIUS_DEFAULT = 3.0;

} // namespace AS_[EffectName]

// ============================================================================
// TEXTURES & SAMPLERS (for multi-pass effects)
// ============================================================================
/*
// Example: Intermediate texture for 2-pass separable Gaussian blur
texture EffectTempTex { Width = BUFFER_WIDTH; Height = BUFFER_HEIGHT; Format = RGBA8; };
sampler EffectTempSampler { Texture = EffectTempTex; };
*/

// ============================================================================
// UI CONTROLS
// ============================================================================

// ---- Effect-Specific Parameters ----
// GFX shaders typically have processing parameters, NOT position/scale
uniform float EffectIntensity < ui_type = "slider"; ui_label = "Effect Intensity"; ui_tooltip = "Overall intensity of the effect"; ui_min = AS_[EffectName]::EFFECT_INTENSITY_MIN; ui_max = AS_[EffectName]::EFFECT_INTENSITY_MAX; ui_step = 0.01; ui_category = "Effect"; > = AS_[EffectName]::EFFECT_INTENSITY_DEFAULT;

// Processing Parameters (example for image enhancement)
uniform float Contrast < ui_type = "slider"; ui_label = "Contrast"; ui_tooltip = "Adjust image contrast"; ui_min = 0.0; ui_max = 2.0; ui_step = 0.01; ui_category = "Processing"; > = 1.0;
uniform float Saturation < ui_type = "slider"; ui_label = "Saturation"; ui_tooltip = "Adjust color saturation"; ui_min = 0.0; ui_max = 2.0; ui_step = 0.01; ui_category = "Processing"; > = 1.0;

/*
// Example: Blur radius for multi-pass Gaussian
uniform float BlurRadius < ui_type = "slider"; ui_label = "Blur Radius"; ui_tooltip = "Radius of the blur effect in pixels"; ui_min = AS_[EffectName]::BLUR_RADIUS_MIN; ui_max = AS_[EffectName]::BLUR_RADIUS_MAX; ui_step = 0.1; ui_category = "Processing"; > = AS_[EffectName]::BLUR_RADIUS_DEFAULT;
*/

// ---- Standard Controls (canonical order) ----
// Note: GFX shaders typically omit Palette & Style, Position/Scale, and Rotation

// Animation (optional for GFX)
// AS_ANIMATION_UI(AnimationSpeed, AnimationKeyframe, AS_CAT_ANIMATION)

// Audio Reactivity (optional for GFX)
AS_AUDIO_UI(Effect_AudioSource, "Audio Source", AS_AUDIO_BEAT, AS_CAT_AUDIO)
AS_AUDIO_MULT_UI(Effect_AudioMultiplier, "Audio Intensity", 1.0, 2.0, AS_CAT_AUDIO)
AS_AUDIO_TARGET_UI(EffectName_AudioTarget, "None\0Effect Intensity\0Contrast\0", 0)

// Stage (GFX uses depth for depth-aware compositing, but NOT position/scale)
AS_STAGEDEPTH_UI(EffectDepth)

// Final Mix
AS_BLENDMODE_UI_DEFAULT(BlendMode, AS_BLEND_NORMAL)
AS_BLENDAMOUNT_UI(BlendStrength)

// Debug
AS_DEBUG_UI("Off\0Show Audio\0Show Depth\0")

// ============================================================================
// RE-ENTER NAMESPACE FOR FUNCTIONS & PIXEL SHADER
// ============================================================================
namespace AS_[EffectName] {

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

// Function to apply image processing
float3 applyProcessing(float3 color, float contrast, float saturation) {
    // Apply contrast
    color = (color - 0.5) * contrast + 0.5;

    // Apply saturation
    float luminance = dot(color, float3(0.299, 0.587, 0.114));
    color = lerp(luminance.xxx, color, saturation);

    return saturate(color);
}

/*
// ============================================================================
// MULTI-PASS BLUR EXAMPLE (2-pass separable Gaussian)
// ============================================================================
// Pass 1: Horizontal blur -> writes to EffectTempTex
float4 BlurHorizontalPS(float4 vpos : SV_POSITION, float2 texcoord : TEXCOORD) : SV_TARGET {
    float3 color = float3(0.0, 0.0, 0.0);
    float totalWeight = 0.0;
    float2 pixelSize = 1.0 / float2(BUFFER_WIDTH, BUFFER_HEIGHT);

    // 9-tap Gaussian kernel (sigma ~= BlurRadius / 3)
    for (int i = -4; i <= 4; i++) {
        float weight = exp(-0.5 * (i * i) / (BlurRadius * BlurRadius * 0.11 + 0.001));
        float2 offset = float2(i * pixelSize.x * BlurRadius * 0.25, 0.0);
        color += tex2Dlod(ReShade::BackBuffer, float4(texcoord + offset, 0, 0)).rgb * weight;
        totalWeight += weight;
    }

    return float4(color / totalWeight, 1.0);
}

// Pass 2: Vertical blur -> reads from EffectTempTex
float4 BlurVerticalPS(float4 vpos : SV_POSITION, float2 texcoord : TEXCOORD) : SV_TARGET {
    float3 color = float3(0.0, 0.0, 0.0);
    float totalWeight = 0.0;
    float2 pixelSize = 1.0 / float2(BUFFER_WIDTH, BUFFER_HEIGHT);

    for (int i = -4; i <= 4; i++) {
        float weight = exp(-0.5 * (i * i) / (BlurRadius * BlurRadius * 0.11 + 0.001));
        float2 offset = float2(0.0, i * pixelSize.y * BlurRadius * 0.25);
        color += tex2Dlod(EffectTempSampler, float4(texcoord + offset, 0, 0)).rgb * weight;
        totalWeight += weight;
    }

    float3 blurred = color / totalWeight;
    float4 originalColor = tex2D(ReShade::BackBuffer, texcoord);

    // Depth-aware compositing: only apply to pixels beyond EffectDepth
    float depth = ReShade::GetLinearizedDepth(texcoord);
    if (depth < EffectDepth) {
        return originalColor;
    }

    return float4(AS_composite(blurred, originalColor.rgb, BlendMode, BlendStrength), 1.0);
}
*/

// ============================================================================
// PIXEL SHADER (single-pass example)
// ============================================================================
float4 EffectPS(float4 vpos : SV_POSITION, float2 texcoord : TEXCOORD) : SV_TARGET {
    float4 originalColor = tex2D(ReShade::BackBuffer, texcoord);

    // --- DEPTH-AWARE COMPOSITING ---
    // GFX shaders can optionally respect depth for selective application
    float depth = ReShade::GetLinearizedDepth(texcoord);
    if (depth < EffectDepth) {
        return originalColor;
    }

    // --- AUDIO REACTIVITY ---
    float effectIntensity = EffectIntensity;
    float contrast = Contrast;

    float audioValue = AS_audioModulate(1.0, Effect_AudioSource, Effect_AudioMultiplier, true, 0);
    if (EffectName_AudioTarget == 1) effectIntensity *= audioValue;
    else if (EffectName_AudioTarget == 2) contrast *= audioValue;

    // --- PROCESSING ---
    float3 processedColor = applyProcessing(originalColor.rgb, contrast, Saturation);

    // Apply effect intensity (lerp between original and processed)
    float3 effectColor = lerp(originalColor.rgb, processedColor, effectIntensity);

    // --- FINAL COMPOSITING ---
    float3 finalRgb = AS_composite(effectColor, originalColor.rgb, BlendMode, BlendStrength);

    // --- DEBUG ---
    if (DebugMode == 1) {
        float2 debugCenter = float2(0.1, 0.1);
        if (length(texcoord - debugCenter) < 0.08) {
            return float4(audioValue, audioValue, audioValue, 1.0);
        }
    } else if (DebugMode == 2) {
        // Show depth buffer
        return float4(depth, depth, depth, 1.0);
    }

    return float4(finalRgb, 1.0);
}

} // namespace AS_[EffectName]

// ============================================================================
// TECHNIQUE
// ============================================================================
// Single-pass technique:
technique AS_GFX_[EffectName] < ui_label="[AS] GFX: [Effect Display Name]"; ui_tooltip="[Description of the graphics effect]"; >
{
    pass
    {
        VertexShader = PostProcessVS;
        PixelShader = AS_[EffectName]::EffectPS;
    }
}

/*
// Multi-pass technique (2-pass separable Gaussian blur example):
technique AS_GFX_[EffectName] < ui_label="[AS] GFX: [Effect Display Name]"; ui_tooltip="[Description]"; >
{
    pass HorizontalBlur
    {
        VertexShader = PostProcessVS;
        PixelShader = AS_[EffectName]::BlurHorizontalPS;
        RenderTarget = EffectTempTex;
    }
    pass VerticalBlurAndComposite
    {
        VertexShader = PostProcessVS;
        PixelShader = AS_[EffectName]::BlurVerticalPS;
    }
}
*/

#endif // __AS_GFX_[EffectName]_1_fx
