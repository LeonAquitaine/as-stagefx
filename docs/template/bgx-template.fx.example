// AS_BGX_[EffectName].1.fx - Background Effect Template (Mode A: Generator)
// Replace [EffectName] with your effect name (e.g., "CosmicStorm")
//
// BGX shaders generate full-screen procedural backgrounds.
// They include ALL standard controls: position, scale, rotation, animation,
// audio reactivity, palette, depth, blend, and debug.

/**
 * AS_BGX_[EffectName].1.fx - [Brief Description]
 * Author: [Author Name]
 * License: Creative Commons Attribution 4.0 International
 * You are free to use, share, and adapt this shader for any purpose, including commercially, as long as you provide attribution.
 *
 * CREDITS (Optional):
 * Based on "[Original Title]" by [Original Author]
 * [Platform]: [URL]
 *
 * ===================================================================================
 *
 * DESCRIPTION:
 * [2-3 sentences describing what the background effect does.]
 *
 * FEATURES:
 * - [Feature list]
 *
 * IMPLEMENTATION OVERVIEW:
 * 1. [Steps]
 *
 * ===================================================================================
 */

// ============================================================================
// TECHNIQUE GUARD
// ============================================================================
#ifndef __AS_BGX_[EffectName]_1_fx
#define __AS_BGX_[EffectName]_1_fx

// ============================================================================
// INCLUDES
// ============================================================================
#include "ReShade.fxh"
#include "AS_Utils.1.fxh"
#include "AS_Palette.1.fxh"

// ============================================================================
// SHADER DESCRIPTOR
// ============================================================================
uniform int as_shader_descriptor <ui_type = "radio"; ui_label = " "; ui_text = "AS StageFX | [Effect Display Name] | [1-2 sentence description of what the effect does visually] | by [Author Name]"; > = 0;

// ============================================================================
// NAMESPACE
// ============================================================================
namespace AS_[EffectName] {

// ============================================================================
// TUNABLE CONSTANTS
// ============================================================================
static const float PATTERN_SCALE_MIN = 1.0;
static const float PATTERN_SCALE_MAX = 20.0;
static const float PATTERN_SCALE_DEFAULT = 5.0;

} // namespace AS_[EffectName]

// ============================================================================
// UI CONTROLS
// ============================================================================

// ---- Effect-Specific Parameters ----
// Pattern Controls
uniform float PatternScale < ui_type = "slider"; ui_label = "Pattern Scale"; ui_min = AS_[EffectName]::PATTERN_SCALE_MIN; ui_max = AS_[EffectName]::PATTERN_SCALE_MAX; ui_category = "Pattern"; > = AS_[EffectName]::PATTERN_SCALE_DEFAULT;
uniform float PatternComplexity < ui_type = "slider"; ui_label = "Pattern Complexity"; ui_min = 1.0; ui_max = 10.0; ui_category = "Pattern"; > = 5.0;

// ---- Standard Controls (canonical order) ----

// Palette & Style
AS_PALETTE_SELECTION_UI(EffectPalette, "Color Palette", AS_PALETTE_FIRE, AS_CAT_PALETTE)
AS_DECLARE_CUSTOM_PALETTE(Effect_, AS_CAT_PALETTE)
AS_USE_PALETTE_UI(UseOriginalColors, AS_CAT_PALETTE)
AS_COLOR_CYCLE_UI(ColorCycleSpeed, AS_CAT_PALETTE)
AS_BACKGROUND_COLOR_UI(BackgroundColor, float3(0.0, 0.0, 0.0), AS_CAT_PALETTE)

// Animation
AS_ANIMATION_UI(AnimationSpeed, AnimationKeyframe, AS_CAT_ANIMATION)

// Audio Reactivity
AS_AUDIO_UI(Effect_AudioSource, "Audio Source", AS_AUDIO_BEAT, AS_CAT_AUDIO)
AS_AUDIO_MULT_UI(Effect_AudioMultiplier, "Audio Intensity", 1.0, 2.0, AS_CAT_AUDIO)
AS_AUDIO_TARGET_UI(EffectName_AudioTarget, "None\0Pattern Scale\0Complexity\0Animation Speed\0", 0)

// Stage
AS_POSITION_SCALE_UI(EffectCenter, EffectScale)
AS_STAGEDEPTH_UI(EffectDepth)
AS_ROTATION_UI(EffectRotationSnap, EffectRotationFine)

// Final Mix
AS_BLENDMODE_UI_DEFAULT(BlendMode, AS_BLEND_NORMAL)
AS_BLENDAMOUNT_UI(BlendStrength)

// Debug
AS_DEBUG_UI("Off\0Show Audio\0Show Coordinates\0")

// ============================================================================
// RE-ENTER NAMESPACE FOR FUNCTIONS & PIXEL SHADER
// ============================================================================
namespace AS_[EffectName] {

// ============================================================================
// PIXEL SHADER
// ============================================================================
float4 EffectPS(float4 vpos : SV_POSITION, float2 texcoord : TEXCOORD) : SV_TARGET {
    float4 originalColor = tex2D(ReShade::BackBuffer, texcoord);
    float depth = ReShade::GetLinearizedDepth(texcoord);

    // Depth test - render behind scene objects
    if (depth < EffectDepth) {
        return originalColor;
    }

    // --- AUDIO REACTIVITY ---
    float patternScale = PatternScale;
    float complexity = PatternComplexity;
    float animSpeed = AnimationSpeed;

    float audioValue = AS_audioModulate(1.0, Effect_AudioSource, Effect_AudioMultiplier, true, 0);
    if (EffectName_AudioTarget == 1) patternScale *= audioValue;
    else if (EffectName_AudioTarget == 2) complexity *= audioValue;
    else if (EffectName_AudioTarget == 3) animSpeed *= audioValue;

    // --- ANIMATION ---
    float time = AS_getAnimationTime(animSpeed, AnimationKeyframe);

    // --- COORDINATE TRANSFORMATION ---
    float rotation = AS_getRotationRadians(EffectRotationSnap, EffectRotationFine);
    float2 coords = (texcoord - AS_HALF) * 2.0;
    coords.x *= ReShade::AspectRatio;
    coords = AS_rotate2D(coords, -rotation);
    coords = coords / EffectScale - EffectCenter;

    // --- IMPLEMENT YOUR BACKGROUND PATTERN HERE ---
    // Example: Simple noise-based pattern
    float2 noiseCoords = coords * patternScale + time * 0.1;
    float noiseValue = AS_PerlinNoise2D(noiseCoords);

    // Apply complexity (multiple octaves)
    for (int i = 1; i < complexity; i++) {
        noiseCoords *= 2.0;
        noiseValue += AS_PerlinNoise2D(noiseCoords) / pow(2.0, i);
    }

    noiseValue = saturate(noiseValue * 0.5 + 0.5);

    // --- COLOR FROM PALETTE ---
    // Apply color cycling offset
    float colorPos = noiseValue;
    if (abs(ColorCycleSpeed) > AS_EPSILON) {
        colorPos = frac(colorPos + AS_timeSeconds() * ColorCycleSpeed * 0.1);
    }

    float3 effectColor;
    if (!UseOriginalColors) {
        // Use palette coloring
        if (EffectPalette == AS_PALETTE_CUSTOM) {
            effectColor = AS_GET_INTERPOLATED_CUSTOM_COLOR(Effect_, colorPos);
        } else {
            effectColor = AS_getInterpolatedColor(EffectPalette, colorPos);
        }
    } else {
        // Use mathematical / original coloring
        effectColor = float3(noiseValue, noiseValue * 0.8, noiseValue * 0.6);
    }

    // Mix with background color
    effectColor = lerp(BackgroundColor, effectColor, noiseValue);

    // --- FINAL COMPOSITING ---
    // Use AS_composite for final output (combines blend mode + strength)
    float3 finalRgb = AS_composite(effectColor, originalColor.rgb, BlendMode, BlendStrength);

    // --- DEBUG ---
    if (DebugMode == 1) {
        float2 debugCenter = float2(0.1, 0.1);
        if (length(texcoord - debugCenter) < 0.08) {
            return float4(audioValue, audioValue, audioValue, 1.0);
        }
    } else if (DebugMode == 2) {
        float2 debugCenter = float2(0.1, 0.1);
        if (length(texcoord - debugCenter) < 0.08) {
            return float4(frac(abs(coords)), 0.0, 1.0);
        }
    }

    return float4(finalRgb, 1.0);
}

} // namespace AS_[EffectName]

// ============================================================================
// TECHNIQUE
// ============================================================================
technique AS_BGX_[EffectName] < ui_label="[AS] BGX: [Effect Display Name]"; ui_tooltip="[Description of the background effect]"; >
{
    pass
    {
        VertexShader = PostProcessVS;
        PixelShader = AS_[EffectName]::EffectPS;
    }
}

#endif // __AS_BGX_[EffectName]_1_fx
