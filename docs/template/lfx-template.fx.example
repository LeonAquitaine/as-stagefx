// AS_LFX_[EffectName].1.fx - Lighting Effect Template (Mode E: Multi-Instance)
// Replace [EffectName] with your effect name (e.g., "Fireflies")
//
// LFX shaders simulate lighting with multiple instances.
// They use the per-instance macro pattern with a Params struct and getter function.
// Each instance can have its own audio source selection.

/**
 * AS_LFX_[EffectName].1.fx - [Brief Description]
 * Author: [Author Name]
 * License: Creative Commons Attribution 4.0 International
 * You are free to use, share, and adapt this shader for any purpose, including commercially, as long as you provide attribution.
 *
 * CREDITS (Optional):
 * Based on "[Original Title]" by [Original Author]
 * [Platform]: [URL]
 *
 * ===================================================================================
 *
 * DESCRIPTION:
 * [2-3 sentences describing the lighting effect.]
 *
 * FEATURES:
 * - [Feature list]
 *
 * IMPLEMENTATION OVERVIEW:
 * 1. [Steps]
 *
 * ===================================================================================
 */

// ============================================================================
// TECHNIQUE GUARD
// ============================================================================
#ifndef __AS_LFX_[EffectName]_1_fx
#define __AS_LFX_[EffectName]_1_fx

// ============================================================================
// INCLUDES
// ============================================================================
#include "ReShade.fxh"
#include "AS_Utils.1.fxh"
#include "AS_Palette.1.fxh"

// ============================================================================
// SHADER DESCRIPTOR
// ============================================================================
uniform int as_shader_descriptor <ui_type = "radio"; ui_label = " "; ui_text = "AS StageFX | [Effect Display Name] | [1-2 sentence description of what the effect does visually] | by [Author Name]"; > = 0;

// ============================================================================
// TUNABLE CONSTANTS
// ============================================================================
static const int LIGHT_COUNT = 4; // Number of light instances

static const float LIGHT_SIZE_MIN = 0.01;
static const float LIGHT_SIZE_MAX = 0.3;
static const float LIGHT_SIZE_DEFAULT = 0.1;

static const float LIGHT_INTENSITY_MIN = 0.0;
static const float LIGHT_INTENSITY_MAX = 2.0;
static const float LIGHT_INTENSITY_DEFAULT = 1.0;

// ============================================================================
// LIGHT INSTANCE UI MACRO
// ============================================================================
// Each instance has its own enable, position, size, intensity, depth,
// and per-instance audio source selection.
#define EFFECT_UI(index, defaultEnable, defaultPosition, defaultSize, defaultIntensity, defaultDepth, defaultAudioSource) \
uniform bool Light##index##_Enable < ui_label = "Enable Light " #index; ui_category = "Light " #index; ui_category_closed = index > 1; > = defaultEnable; \
uniform float2 Light##index##_Position < ui_type = "slider"; ui_label = "Position (X, Y)"; ui_tooltip = "Screen position. (0,0) is center, [-1,1] covers the central square."; ui_min = -1.5; ui_max = 1.5; ui_step = 0.01; ui_category = "Light " #index; > = defaultPosition; \
uniform float Light##index##_Size < ui_type = "slider"; ui_label = "Size"; ui_min = LIGHT_SIZE_MIN; ui_max = LIGHT_SIZE_MAX; ui_step = 0.01; ui_category = "Light " #index; > = defaultSize; \
uniform float Light##index##_Intensity < ui_type = "slider"; ui_label = "Intensity"; ui_min = LIGHT_INTENSITY_MIN; ui_max = LIGHT_INTENSITY_MAX; ui_step = 0.01; ui_category = "Light " #index; > = defaultIntensity; \
uniform float Light##index##_StageDepth < ui_type = "slider"; ui_label = "Depth"; ui_min = 0.0; ui_max = 1.0; ui_step = 0.01; ui_category = "Light " #index; > = defaultDepth; \
uniform int Light##index##_AudioSource < ui_type = "combo"; ui_label = "Audio Source"; ui_items = "Off\0Volume\0Beat\0Bass\0Mid\0Treble\0"; ui_category = "Light " #index; > = defaultAudioSource;

// ============================================================================
// LIGHT INSTANCES (Using the macro)
// ============================================================================
EFFECT_UI(1, true,  float2( 0.0,  0.0), LIGHT_SIZE_DEFAULT, LIGHT_INTENSITY_DEFAULT, 0.05, 2)
EFFECT_UI(2, false, float2( 0.3,  0.3), LIGHT_SIZE_DEFAULT, LIGHT_INTENSITY_DEFAULT, 0.05, 2)
EFFECT_UI(3, false, float2(-0.3,  0.3), LIGHT_SIZE_DEFAULT, LIGHT_INTENSITY_DEFAULT, 0.05, 2)
EFFECT_UI(4, false, float2( 0.0, -0.3), LIGHT_SIZE_DEFAULT, LIGHT_INTENSITY_DEFAULT, 0.05, 2)

// ============================================================================
// GLOBAL CONTROLS
// ============================================================================

// ---- Standard Controls (canonical order) ----

// Palette & Style
AS_PALETTE_SELECTION_UI(LightPalette, "Light Color Palette", AS_PALETTE_FIRE, AS_CAT_PALETTE)
AS_DECLARE_CUSTOM_PALETTE(Light_, AS_CAT_PALETTE)
AS_COLOR_CYCLE_UI(ColorCycleSpeed, AS_CAT_PALETTE)
uniform float LightFalloff < ui_type = "slider"; ui_label = "Light Falloff"; ui_tooltip = "Controls how quickly light fades with distance"; ui_min = 0.5; ui_max = 5.0; ui_category = AS_CAT_APPEARANCE; > = 2.0;
uniform float BloomSize < ui_type = "slider"; ui_label = "Bloom Size"; ui_tooltip = "Size of the bloom/glow effect"; ui_min = 0.0; ui_max = 3.0; ui_category = AS_CAT_APPEARANCE; > = 1.0;

// Animation
AS_ANIMATION_UI(AnimationSpeed, AnimationKeyframe, AS_CAT_ANIMATION)
uniform float FlickerAmount < ui_type = "slider"; ui_label = "Flicker Amount"; ui_tooltip = "Amount of random flickering"; ui_min = 0.0; ui_max = 1.0; ui_category = AS_CAT_ANIMATION; > = 0.1;

// Audio Reactivity (global audio controls affect all instances)
AS_AUDIO_UI(Light_AudioSource, "Audio Source", AS_AUDIO_BEAT, AS_CAT_AUDIO)
AS_AUDIO_MULT_UI(Light_AudioMultiplier, "Audio Intensity", 1.0, 2.0, AS_CAT_AUDIO)
AS_AUDIO_TARGET_UI(EffectName_AudioTarget, "None\0Light Intensity\0Flicker Amount\0Bloom Size\0", 0)

// Stage
AS_ROTATION_UI(GlobalSnapRotation, GlobalFineRotation)

// Final Mix
// Note: For additive light effects, use originalColor.rgb + effectLight pattern
AS_BLENDMODE_UI_DEFAULT(BlendMode, AS_BLEND_LIGHTEN)
AS_BLENDAMOUNT_UI(BlendStrength)

// Debug
AS_DEBUG_UI("Off\0Show Audio\0Show Light Bounds\0")

// ============================================================================
// NAMESPACE & STRUCTURES
// ============================================================================
namespace AS_[EffectName] {

// Structure to hold per-instance parameters
struct LightParams {
    bool enable;
    float2 position;
    float size;
    float intensity;
    float stageDepth;
    int audioSource;
};

// Helper function to get parameters for a given instance index
LightParams GetLightParams(int lightIndex) {
    LightParams params;

    if (lightIndex == 0) {
        params.enable = Light1_Enable;
        params.position = Light1_Position;
        params.size = Light1_Size;
        params.intensity = Light1_Intensity;
        params.stageDepth = Light1_StageDepth;
        params.audioSource = Light1_AudioSource;
    }
    else if (lightIndex == 1) {
        params.enable = Light2_Enable;
        params.position = Light2_Position;
        params.size = Light2_Size;
        params.intensity = Light2_Intensity;
        params.stageDepth = Light2_StageDepth;
        params.audioSource = Light2_AudioSource;
    }
    else if (lightIndex == 2) {
        params.enable = Light3_Enable;
        params.position = Light3_Position;
        params.size = Light3_Size;
        params.intensity = Light3_Intensity;
        params.stageDepth = Light3_StageDepth;
        params.audioSource = Light3_AudioSource;
    }
    else { // lightIndex == 3
        params.enable = Light4_Enable;
        params.position = Light4_Position;
        params.size = Light4_Size;
        params.intensity = Light4_Intensity;
        params.stageDepth = Light4_StageDepth;
        params.audioSource = Light4_AudioSource;
    }

    return params;
}

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

// Calculate light contribution at a given position
float3 calculateLight(float2 texcoord, LightParams light, float time, int lightIndex) {
    float depth = ReShade::GetLinearizedDepth(texcoord);

    // Skip if light is behind scene geometry
    if (depth < light.stageDepth) {
        return float3(0, 0, 0);
    }

    // Transform coordinates to light space
    float2 coords = texcoord - light.position;
    coords.x *= ReShade::AspectRatio;

    // Calculate distance from light center
    float distance = length(coords) / light.size;

    // Apply per-instance audio reactivity
    float intensity = light.intensity;
    float audioLevel = AS_audioLevelFromSource(light.audioSource);
    intensity *= lerp(1.0, audioLevel * Light_AudioMultiplier, step(1.0, float(light.audioSource)));

    // Apply flicker using noise
    float flicker = 1.0 + (AS_hash11(time + lightIndex) - 0.5) * FlickerAmount;
    flicker = max(0.1, flicker);

    // Calculate light falloff
    float attenuation = pow(1.0 / (1.0 + distance * LightFalloff), 2.0);
    attenuation *= intensity * flicker;

    // Add bloom effect
    float bloom = 1.0 / (1.0 + distance * distance / (BloomSize * BloomSize));
    attenuation += bloom * 0.3;

    // Get color from palette
    float colorPos = saturate(attenuation);
    if (abs(ColorCycleSpeed) > AS_EPSILON) {
        colorPos = frac(colorPos + AS_timeSeconds() * ColorCycleSpeed * 0.1);
    }

    float3 lightColor;
    if (LightPalette == AS_PALETTE_CUSTOM) {
        lightColor = AS_GET_INTERPOLATED_CUSTOM_COLOR(Light_, colorPos);
    } else {
        lightColor = AS_getInterpolatedColor(LightPalette, colorPos);
    }

    return lightColor * attenuation;
}

// ============================================================================
// PIXEL SHADER
// ============================================================================
float4 EffectPS(float4 vpos : SV_POSITION, float2 texcoord : TEXCOORD) : SV_TARGET {
    float4 originalColor = tex2D(ReShade::BackBuffer, texcoord);

    // --- GLOBAL AUDIO REACTIVITY ---
    float audioValue = AS_audioModulate(1.0, Light_AudioSource, Light_AudioMultiplier, true, 0);
    // (AudioTarget affects global params like flicker, bloom - applied in calculateLight)

    // --- ANIMATION ---
    float time = AS_getAnimationTime(AnimationSpeed, AnimationKeyframe);

    // --- ACCUMULATE LIGHT CONTRIBUTIONS ---
    float3 totalLight = float3(0, 0, 0);

    // Process each light instance using the struct/getter pattern
    for (int i = 0; i < LIGHT_COUNT; i++) {
        LightParams light = GetLightParams(i);
        if (light.enable) {
            totalLight += calculateLight(texcoord, light, time, i);
        }
    }

    // --- FINAL COMPOSITING ---
    // For additive light effects: originalColor.rgb + totalLight
    // For standard compositing via user blend mode:
    float3 finalRgb = AS_composite(totalLight, originalColor.rgb, BlendMode, BlendStrength);

    // --- DEBUG ---
    if (DebugMode == 1) { // Show Audio
        float2 debugCenter = float2(0.1, 0.1);
        if (length(texcoord - debugCenter) < 0.08) {
            return float4(audioValue, audioValue, audioValue, 1.0);
        }
    } else if (DebugMode == 2) { // Show Light Bounds
        for (int j = 0; j < LIGHT_COUNT; j++) {
            LightParams light = GetLightParams(j);
            if (light.enable) {
                float2 coords = texcoord - light.position;
                coords.x *= ReShade::AspectRatio;
                float dist = length(coords) / light.size;
                if (abs(dist - 1.0) < 0.05) {
                    float3 debugColors[4] = { float3(1,0,0), float3(0,1,0), float3(0,0,1), float3(1,1,0) };
                    return float4(debugColors[j], 1.0);
                }
            }
        }
    }

    return float4(finalRgb, 1.0);
}

} // namespace AS_[EffectName]

// ============================================================================
// TECHNIQUE
// ============================================================================
technique AS_LFX_[EffectName] < ui_label="[AS] LFX: [Effect Display Name]"; ui_tooltip="[Description of the lighting effect]"; >
{
    pass
    {
        VertexShader = PostProcessVS;
        PixelShader = AS_[EffectName]::EffectPS;
    }
}

#endif // __AS_LFX_[EffectName]_1_fx
